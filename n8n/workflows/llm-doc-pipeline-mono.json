        "language": "javaScript",
        "jsCode": "const items = $input.all();\nfor (const it of items) {\n  const j = it.json;\n  const t = (j.body ?? '').toString();\n  let parsed = {};\n  try { parsed = t.trim() ? JSON.parse(t) : {}; } catch (e) { parsed = {}; }\n  const usage = (parsed && parsed.usage) || {};\n  const stageCost = (Number(usage.prompt_tokens || 0) + Number(usage.completion_tokens || 0)) / 1e6;\n  j.__cost = (Number(j.__cost) || 0) + stageCost;\n  j.__result = { document: parsed, combined: j.__combined || {}, cost_usd: j.__cost };\n}\nreturn items;"
