              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Title",
              "value": "STUDIO template"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"anthropic/claude-sonnet-4-6\", temperature: 0.2, max_tokens: 4096, messages: ([{ role: \"user\", content: \"Analyse: \" + JSON.stringify($json.body || {}) }]) }) }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth"
      },
      "alwaysOutputData": true,
      "notes": "PAT-4 guard: body may be an empty HTTP 200 — never JSON.parse blind. Use: const t=(response.body??'').toString(); t.trim()?JSON.parse(t):[]"
    },
    {
      "id": "cost-log-spend-flag",
      "name": "Cost Log + Spend Flag",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        -120
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const BUDGET = Number($env['LLM_DAILY_BUDGET_USD'] || '5');\nconst items = $input.all();\nfor (const it of items) {\n  const j = it.json;\n  const t = (j.body ?? '').toString();\n  let parsed = {};\n  try { parsed = t.trim() ? JSON.parse(t) : {}; } catch (e) { parsed = {}; }\n  const usage = (parsed && parsed.usage) || {};\n  const inTok = Number(usage.prompt_tokens || 0);\n  const outTok = Number(usage.completion_tokens || 0);\n  // Coarse per-stage estimate; the studio reconciles exact spend out of band.\n  const stageCost = (inTok + outTok) / 1e6;\n  j.__cost = (Number(j.__cost) || 0) + stageCost;\n  j.__analysis = parsed;\n  j.__spend_ok = j.__cost <= BUDGET;\n}\nreturn items;"
      },
      "alwaysOutputData": true
    },
    {
