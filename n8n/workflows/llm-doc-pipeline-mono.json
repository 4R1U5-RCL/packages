        "jsCode": "const items = $input.all();\nfor (const it of items) {\n  const j = it.json;\n  const t = (j.body ?? '').toString();\n  let mapped = {};\n  try { mapped = t.trim() ? JSON.parse(t) : {}; } catch (e) { mapped = {}; }\n  j.__mapped = mapped;\n  j.__combined = { analysis: j.__analysis || {}, mapped };\n}\nreturn items;"
