        "jsCode": "const FROM = \"{{ $env.REPORT_FROM_ADDRESS }}\";\nconst items = $input.all();\nfor (const it of items) {\n  const b = it.json.__payload || {};\n  it.json.__email = {\n    from: FROM,\n    to: b.to,\n    subject: b.subject || 'Report',\n    html: '<pre>' + JSON.stringify(b.report || {}, null, 2) + '</pre>',\n  };\n}\nreturn items;"
      }
    },
