        "language": "javaScript",
        "jsCode": "const crypto = require('crypto');\nconst SECRET = $env[\"N8N_WEBHOOK_SECRET\"];\nconst out = [];\nfor (const it of $input.all()) {\n  const res = it.json;\n  // PAT-4: the upstream guardedHttp returns { statusCode, body } and never throws;\n  // the body may be an empty 200 — never JSON.parse blind.\n  const t = (res.body ?? '').toString();\n  let rows;\n  try { rows = t.trim() ? JSON.parse(t) : []; } catch (e) { rows = []; }\n  const body = { ok: true, count: Array.isArray(rows) ? rows.length : 0, data: rows };\n  const payload = JSON.stringify(body);\n  out.push({ json: {\n    __body: body,\n    __ts: String(Date.now()),\n    __sig: crypto.createHmac('sha256', SECRET).update(payload).digest('hex'),\n  } });\n}\nreturn out;"
