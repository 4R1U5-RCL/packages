      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nfor (const it of items) {\n  const b = it.json.body || it.json;\n  const text = (b.Body || b.text || b.message || '').toString();\n  it.json.__from = b.From || b.from || '';\n  it.json.__text = text;\n  it.json.__msgId = b.MessageSid || b.message_id || '';\n  it.json.__optout = ['STOP', 'STOPALL', 'UNSUBSCRIBE', 'CANCEL', 'END', 'QUIT']\n    .includes(text.trim().toUpperCase());\n}\nreturn items;"
      }
    },
